<?xml version="1.0" encoding="utf-8"?>
<xs:schema xmlns:tns="http://schemas.datacontract.org/2004/07/SampleProjectWCF" elementFormDefault="qualified" targetNamespace="http://schemas.datacontract.org/2004/07/SampleProjectWCF" xmlns:xs="http://www.w3.org/2001/XMLSchema">
  <xs:complexType name="PerformanceModel">
    <xs:sequence>
      <xs:element minOccurs="0" name="AverageScore" type="xs:decimal" />
      <xs:element minOccurs="0" name="Communication" type="xs:decimal" />
      <xs:element minOccurs="0" name="Consistency" type="xs:decimal" />
      <xs:element minOccurs="0" name="Feedback" nillable="true" type="xs:string" />
      <xs:element minOccurs="0" name="Initiative" type="xs:decimal" />
      <xs:element minOccurs="0" name="LearningAbility" type="xs:decimal" />
