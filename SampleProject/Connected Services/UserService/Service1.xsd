      <xs:element minOccurs="0" name="ProblemSolving" type="xs:decimal" />
      <xs:element minOccurs="0" name="Productivity" type="xs:decimal" />
      <xs:element minOccurs="0" name="Punctuality" type="xs:decimal" />
      <xs:element minOccurs="0" name="QualityOfWork" type="xs:decimal" />
      <xs:element minOccurs="0" name="TaskCompletion" type="xs:decimal" />
      <xs:element minOccurs="0" name="Teamwork" type="xs:decimal" />
      <xs:element minOccurs="0" name="UserId" type="xs:int" />
    </xs:sequence>
  </xs:complexType>
  <xs:element name="PerformanceModel" nillable="true" type="tns:PerformanceModel" />
  <xs:complexType name="ArrayOfPerformanceModel">
    <xs:sequence>
      <xs:element minOccurs="0" maxOccurs="unbounded" name="PerformanceModel" nillable="true" type="tns:PerformanceModel" />
