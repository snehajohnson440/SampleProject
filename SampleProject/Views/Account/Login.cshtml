@model SampleProject.Models.LoginViewModel
@{ Layout = null; }

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Login</title>

   
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

   
<link href="~/Content/LoginAndRegister/loginstyle.css" rel="stylesheet" />
</head>

<body>

<div class="background"></div>

<div class="wrapper">

<!-- LEFT INFO -->
<div class="info">
<h2>Manage your work smarter</h2>
<p>
A simple and secure platform to organize projects,
collaborate effortlessly, and stay focused on what matters most.
</p>
</div>

<!-- LOGIN PANEL -->
<div class="glass-panel">

<h1>Log in</h1>
<p class="subtitle">Access your dashboard</p>

@using (Html.BeginForm("Login", "Account", FormMethod.Post))
{
if (ViewBag.Error != null)
{
<div class="error">@ViewBag.Error</div> }

<div class="form-group">
<label>Email</label>
@Html.TextBoxFor(m => m.Email, new
{
type = "email",
placeholder = "Enter your email"
})
@Html.ValidationMessageFor(m => m.Email, "", new { @class = "error" })
</div>

<div class="form-group">
<label>Password</label>
@Html.PasswordFor(m => m.Password, new
{
placeholder = "••••••••"
})
@Html.ValidationMessageFor(m => m.Password, "", new { @class = "error" })
</div>

<button type="submit">Log In</button>

<div class="footer">
Don’t have an account?
<a href="@Url.Action("Register","Account")">Register</a>
</div>      }

</div>

</div>
@if (TempData["Success"] != null)
{
<script>
alert('@TempData["Success"]');
</script>}
</body>
</html>
